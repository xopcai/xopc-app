{
  "name": "xopc",
  "version": "0.0.2",
  "private": true,
  "description": "Expo mobile client for the xopc gateway",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:offline": "expo start --offline",
    "start:no-proxy": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= expo start",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:no-proxy": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" expo run:ios",
    "pods:install": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" sh -c 'test -f ios/Podfile || (echo \"Missing ios/Podfile — run: pnpm exec expo prebuild\" >&2 && exit 1); cd ios && pod install'",
    "ios:no-install": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" expo run:ios --no-install",
    "web": "expo start --web",
    "lint": "eslint app src",
    "typecheck": "tsc --noEmit && pnpm -C packages/gateway-sse-client run typecheck",
    "test": "vitest run",
    "test:gateway-sse-client": "vitest run packages/gateway-sse-client",
    "release:patch": "bash scripts/release-patch.sh",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/react-query": "^5.100.6",
    "@xopcai/gateway-sse-client": "workspace:*",
    "expo": "~54.0.33",
    "expo-av": "^16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "^18.0.13",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "^19.0.22",
    "expo-image-picker": "^17.0.11",
    "expo-linking": "^8.0.12",
    "expo-router": "^6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.81.5",
    "react-native-enriched-markdown": "^0.5.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-paper": "^5.15.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@expo/config-plugins": "~54.0.4",
    "@types/react": "~19.2.3",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^19.0.8",
    "eslint": "^9.39.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@9.15.9"
}
