{
  "name": "xopc",
  "version": "0.0.1",
  "private": true,
  "description": "Expo mobile client for the xopc gateway",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:offline": "expo start --offline",
    "start:no-proxy": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= expo start",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:no-proxy": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" expo run:ios",
    "pods:install": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" sh -c 'test -f ios/Podfile || (echo \"Missing ios/Podfile — run: pnpm exec expo prebuild\" >&2 && exit 1); cd ios && pod install'",
    "ios:no-install": "HTTPS_PROXY= HTTP_PROXY= ALL_PROXY= http_proxy= https_proxy= PATH=\"/opt/homebrew/bin:$PATH\" expo run:ios --no-install",
    "web": "expo start --web",
    "lint": "eslint app src",
    "typecheck": "tsc --noEmit && pnpm -C packages/gateway-sse-client run typecheck",
    "test": "vitest run",
    "test:note-editor": "vitest run src/features/notes/__tests__/markdown-document.test.ts src/features/notes/__tests__/markdown-editing.test.ts src/features/notes/__tests__/markdown-insert.test.ts src/features/notes/__tests__/markdown-link-index.test.ts src/features/notes/__tests__/markdown-patch.test.ts src/features/notes/__tests__/notes-local.test.ts src/query/__tests__/note-link-index.test.ts",
    "test:gateway-sse-client": "vitest run packages/gateway-sse-client",
    "release:patch": "bash scripts/release-patch.sh",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:eas": "eas build --platform ios --profile production",
    "build:ios": "bash scripts/build-ios-ipa.sh",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:ios:direct": "bash scripts/upload-ios-ipa.sh"
  },
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@expo/dom-webview": "56.0.5",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.100.6",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@xopcai/gateway-sse-client": "workspace:*",
    "expo": "~56.0.12",
    "expo-asset": "^56.0.17",
    "expo-audio": "~56.0.12",
    "expo-blur": "^56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "^56.0.4",
    "expo-constants": "^56.0.18",
    "expo-document-picker": "^56.0.4",
    "expo-font": "^56.0.7",
    "expo-haptics": "^56.0.3",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "^56.0.14",
    "expo-router": "^56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.74.0",
    "react-native": "0.85.3",
    "react-native-enriched-markdown": "^0.5.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-markdown-display": "7.0.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-pager-view": "8.0.1",
    "react-native-paper": "^5.15.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "~19.2.3",
    "babel-preset-expo": "~56.0.15",
    "eslint": "^9.39.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@9.15.9"
}
